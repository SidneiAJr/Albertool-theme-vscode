            { "label": "👑 Albertool Prime",       "uiTheme": "vs-dark", "path": "./themes/albertool-prime-color-theme.json" },
            { "label": "🏙️ Albertool Vice City",   "uiTheme": "vs-dark", "path": "./themes/albertool-vicecity-color-theme.json" },
            { "label": "🌊 Albertool Synthwave 84","uiTheme": "vs-dark", "path": "./themes/albertool-synthwave-color-theme.json" },
            { "label": "💚 Albertool Matrix",      "uiTheme": "vs-dark", "path": "./themes/albertool-matrix-color-theme.json" },
            { "label": "🩸 Albertool Crimson",     "uiTheme": "vs-dark", "path": "./themes/albertool-crimson-color-theme.json" },
            { "label": "❄️ Albertool Arctic",      "uiTheme": "vs-dark", "path": "./themes/albertool-arctic-color-theme.json" },
