{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Synthwave 84",
    "type": "dark",
    "colors": {
        "editor.background": "#1a0a2e",
        "editor.foreground": "#f5d0f5",
        "activityBar.background": "#1a0a2e",
        "activityBar.foreground": "#36f9f6",
        "activityBar.inactiveForeground": "#5a3a6a",
        "activityBar.activeBorder": "#36f9f6",
        "sideBar.background": "#1a0a2e",
        "sideBar.foreground": "#c0a0c0",
        "sideBar.border": "#ff7edb22",
        "sideBarTitle.foreground": "#ff7edb",
        "sideBarSectionHeader.background": "#24103a",
        "statusBar.background": "#1a0a2e",
        "statusBar.foreground": "#36f9f6",
        "statusBar.border": "#36f9f622",
        "statusBar.debuggingBackground": "#ff7edb",
        "statusBar.debuggingForeground": "#1a0a2e",
        "titleBar.activeBackground": "#1a0a2e",
        "titleBar.activeForeground": "#36f9f6",
        "titleBar.inactiveBackground": "#1a0a2e",
        "titleBar.inactiveForeground": "#5a3a6a",
        "terminal.background": "#1a0a2e",
        "terminal.foreground": "#f5d0f5",
        "input.background": "#1a0a2e",
        "input.foreground": "#f5d0f5",
        "input.border": "#ff7edb44",
        "list.activeSelectionBackground": "#ff7edb22",
        "list.activeSelectionForeground": "#36f9f6",
        "list.hoverBackground": "#ff7edb11",
        "list.hoverForeground": "#f5d0f5",
        "tab.activeBackground": "#24103a",
        "tab.activeForeground": "#36f9f6",
        "tab.inactiveBackground": "#1a0a2e",
        "tab.inactiveForeground": "#5a3a6a",
        "tab.border": "#ff7edb22",
        "button.background": "#ff7edb",
        "button.foreground": "#1a0a2e",
        "button.hoverBackground": "#e56cc0",
        "badge.background": "#36f9f6",
        "badge.foreground": "#1a0a2e",
        "dropdown.background": "#1a0a2e",
        "dropdown.foreground": "#f5d0f5",
        "dropdown.border": "#ff7edb44",
        "editor.selectionBackground": "#36f9f633",
        "editor.lineHighlightBackground": "#ff7edb11",
        "editorLineNumber.foreground": "#5a3a6a",
        "editorLineNumber.activeForeground": "#36f9f6",
        "scrollbarSlider.background": "#ff7edb33",
        "scrollbarSlider.hoverBackground": "#ff7edb55",
        "scrollbarSlider.activeBackground": "#ff7edb88",
        "focusBorder": "#36f9f6",
        "editorGroupHeader.tabsBackground": "#1a0a2e"
    },
    "tokenColors": [
        {
            "name": "Comentários",
            "scope": ["comment"],
            "settings": { "foreground": "#5a3a6a", "fontStyle": "italic" }
        },
        {
            "name": "Palavras-chave",
            "scope": [
                "keyword",
                "keyword.operator",
                "keyword.control",
                "keyword.control.flow",
                "keyword.control.loop",
                "keyword.control.conditional"
            ],
            "settings": { "foreground": "#ff7edb", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string", "string.quoted", "string.quoted.single", "string.quoted.double"],
            "settings": { "foreground": "#36f9f6" }
        },
        {
            "name": "Números",
            "scope": ["constant.numeric", "constant.hex", "constant.octal"],
            "settings": { "foreground": "#ffea00" }
        },
        {
            "name": "Funções",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#36f9f6", "fontStyle": "bold" }
        },
        {
            "name": "Classes",
            "scope": ["entity.name.class", "entity.name.type.class"],
            "settings": { "foreground": "#ff7edb", "fontStyle": "bold" }
        },
        {
            "name": "Variáveis",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#f5d0f5" }
        },
        {
            "name": "Constantes",
            "scope": ["constant", "constant.language"],
            "settings": { "foreground": "#ffea00" }
        },
        {
            "name": "Tipos",
            "scope": ["entity.name.type", "support.type", "storage.type"],
            "settings": { "foreground": "#b388ff", "fontStyle": "bold" }
        },
        {
            "name": "Operadores",
            "scope": ["keyword.operator", "keyword.operator.assignment"],
            "settings": { "foreground": "#ff7edb" }
        },
        {
            "name": "Tags HTML",
            "scope": ["meta.tag", "entity.name.tag"],
            "settings": { "foreground": "#ff7edb" }
        },
        {
            "name": "Atributos HTML",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#36f9f6" }
        },
        {
            "name": "CSS Props",
            "scope": ["support.type.property-name"],
            "settings": { "foreground": "#36f9f6" }
        },
        {
            "name": "CSS Values",
            "scope": ["support.constant.property-value"],
            "settings": { "foreground": "#ffea00" }
        },
        {
            "name": "JSON Keys",
            "scope": ["support.type.object.key"],
            "settings": { "foreground": "#36f9f6" }
        },
        {
            "name": "JSON Values",
            "scope": ["string.key.json"],
            "settings": { "foreground": "#ff7edb" }
        },
        {
            "name": "Markdown Headings",
            "scope": ["markup.heading", "markup.heading.1", "markup.heading.2"],
            "settings": { "foreground": "#36f9f6", "fontStyle": "bold" }
        },
        {
            "name": "Erros",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#ff0055", "fontStyle": "bold" }
        },
        {
            "name": "Deprecado",
            "scope": ["invalid.deprecated"],
            "settings": { "foreground": "#ffea00" }
        }
    ]
}