{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Simples",
    "type": "dark",
    "colors": {
        "editor.background": "#000000",
        "editor.foreground": "#e0e0e0",
        "activityBar.background": "#000000",
        "activityBar.foreground": "#e0e0e0",
        "sideBar.background": "#000000",
        "sideBar.foreground": "#e0e0e0",
        "statusBar.background": "#000000",
        "statusBar.foreground": "#e0e0e0",
        "titleBar.activeBackground": "#000000",
        "titleBar.activeForeground": "#e0e0e0",
        "terminal.background": "#000000",
        "terminal.foreground": "#e0e0e0",
        "input.background": "#000000",
        "input.foreground": "#e0e0e0",
        "list.activeSelectionBackground": "#222222",
        "list.activeSelectionForeground": "#e0e0e0",
        "tab.activeBackground": "#0a0a0a",
        "tab.activeForeground": "#e0e0e0",
        "tab.inactiveBackground": "#000000",
        "tab.inactiveForeground": "#555555",
        "button.background": "#222222",
        "button.foreground": "#e0e0e0",
        "badge.background": "#222222",
        "badge.foreground": "#e0e0e0",
        "dropdown.background": "#000000",
        "dropdown.foreground": "#e0e0e0",
        "editor.selectionBackground": "#44444444",
        "editor.lineHighlightBackground": "#22222222",
        "editorLineNumber.foreground": "#444444",
        "editorLineNumber.activeForeground": "#e0e0e0",
        "scrollbarSlider.background": "#44444433",
        "scrollbarSlider.hoverBackground": "#44444455",
        "scrollbarSlider.activeBackground": "#44444488",
        "focusBorder": "#e0e0e0"
    },
    "tokenColors": [
        {
            "scope": "comment",
            "settings": { "foreground": "#555555", "fontStyle": "italic" }
        },
        {
            "scope": "keyword",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "keyword.operator",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "string",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "constant.numeric",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "entity.name.function",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "entity.name.class",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "variable",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "entity.name.type",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "support.function",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "constant.language",
            "settings": { "foreground": "#e0e0e0" }
        },
        {
            "scope": "storage.type",
            "settings": { "foreground": "#e0e0e0" }
        }
    ]
}