{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Nebula",
    "type": "dark",
    "colors": {
        "focusBorder": "#c084fc",
        "foreground": "#e9d5ff",
        "selection.background": "#c084fc44",

        "editor.background": "#000000",
        "editor.foreground": "#e9d5ff",
        "editor.lineHighlightBackground": "#c084fc11",
        "editor.selectionBackground": "#c084fc33",
        "editor.selectionHighlightBackground": "#38bdf822",
        "editor.inactiveSelectionBackground": "#c084fc22",

        "editorBracketMatch.background": "#c084fc33",
        "editorBracketMatch.border": "#c084fc",

        "editorGutter.background": "#000000",
        "editorGutter.modifiedBackground": "#c084fc",
        "editorGutter.addedBackground": "#38bdf8",
        "editorGutter.deletedBackground": "#f472b6",

        "editorLineNumber.foreground": "#1a0a2a",
        "editorLineNumber.activeForeground": "#c084fc",

        "editorGroupHeader.tabsBackground": "#000000",
        "tab.activeBackground": "#0a0015",
        "tab.activeForeground": "#c084fc",
        "tab.inactiveBackground": "#000000",
        "tab.inactiveForeground": "#1a0a2a",
        "tab.border": "#c084fc22",

        "activityBar.background": "#000000",
        "activityBar.foreground": "#c084fc",
        "activityBar.inactiveForeground": "#1a0a2a",
        "activityBar.border": "#c084fc22",
        "activityBar.activeBorder": "#c084fc",

        "sideBar.background": "#050010",
        "sideBar.foreground": "#e9d5ff",
        "sideBar.border": "#c084fc22",
        "sideBarTitle.foreground": "#c084fc",
        "sideBarSectionHeader.background": "#0a0015",

        "statusBar.background": "#000000",
        "statusBar.foreground": "#c084fc",
        "statusBar.border": "#c084fc22",
        "statusBar.debuggingBackground": "#c084fc",
        "statusBar.debuggingForeground": "#000000",

        "titleBar.activeBackground": "#000000",
        "titleBar.activeForeground": "#c084fc",
        "titleBar.inactiveBackground": "#000000",
        "titleBar.inactiveForeground": "#1a0a2a",

        "list.activeSelectionBackground": "#0a0015",
        "list.activeSelectionForeground": "#c084fc",
        "list.hoverBackground": "#c084fc11",
        "list.hoverForeground": "#e9d5ff",
        "list.focusBackground": "#0a0015",
        "list.focusForeground": "#c084fc",

        "input.background": "#050010",
        "input.foreground": "#e9d5ff",
        "input.border": "#c084fc44",
        "input.placeholderForeground": "#1a0a2a",

        "dropdown.background": "#050010",
        "dropdown.foreground": "#e9d5ff",
        "dropdown.border": "#c084fc44",

        "button.background": "#c084fc",
        "button.foreground": "#000000",
        "button.hoverBackground": "#a855f7",

        "terminal.background": "#000000",
        "terminal.foreground": "#e9d5ff",

        "badge.background": "#c084fc",
        "badge.foreground": "#000000",

        "scrollbarSlider.background": "#c084fc33",
        "scrollbarSlider.hoverBackground": "#c084fc55",
        "scrollbarSlider.activeBackground": "#c084fc88",

        "peekViewResult.background": "#050010",
        "peekViewResult.selectionBackground": "#0a0015",
        "peekViewResult.lineForeground": "#e9d5ff",
        "peekViewResult.fileForeground": "#c084fc",
        "peekViewEditor.background": "#000000",
        "peekViewEditorGutter.background": "#000000",
        "peekView.border": "#c084fc"
    },
    "tokenColors": [
        {
            "name": "Comentários",
            "scope": ["comment"],
            "settings": { "foreground": "#1a0a2a", "fontStyle": "italic" }
        },
        {
            "name": "Palavras-chave",
            "scope": ["keyword", "keyword.control", "keyword.control.flow", "keyword.control.loop", "keyword.control.conditional"],
            "settings": { "foreground": "#c084fc", "fontStyle": "bold" }
        },
        {
            "name": "Operadores",
            "scope": ["keyword.operator", "keyword.operator.assignment"],
            "settings": { "foreground": "#e9d5ff" }
        },
        {
            "name": "Strings",
            "scope": ["string", "string.quoted.single", "string.quoted.double"],
            "settings": { "foreground": "#38bdf8" }
        },
        {
            "name": "Números",
            "scope": ["constant.numeric", "constant.hex", "constant.octal"],
            "settings": { "foreground": "#f472b6" }
        },
        {
            "name": "Funções",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#38bdf8", "fontStyle": "bold" }
        },
        {
            "name": "Classes",
            "scope": ["entity.name.class", "entity.name.type.class"],
            "settings": { "foreground": "#f472b6", "fontStyle": "bold" }
        },
        {
            "name": "Variáveis",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#e9d5ff" }
        },
        {
            "name": "Constantes",
            "scope": ["constant", "constant.language"],
            "settings": { "foreground": "#f472b6" }
        },
        {
            "name": "Tipos",
            "scope": ["entity.name.type", "support.type", "storage.type"],
            "settings": { "foreground": "#38bdf8" }
        },
        {
            "name": "Tags HTML",
            "scope": ["meta.tag", "entity.name.tag"],
            "settings": { "foreground": "#c084fc" }
        },
        {
            "name": "Atributos HTML",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#38bdf8" }
        },
        {
            "name": "CSS Props",
            "scope": ["support.type.property-name"],
            "settings": { "foreground": "#38bdf8" }
        },
        {
            "name": "CSS Values",
            "scope": ["support.constant.property-value"],
            "settings": { "foreground": "#f472b6" }
        },
        {
            "name": "JSON Keys",
            "scope": ["support.type.object.key", "string.key.json"],
            "settings": { "foreground": "#38bdf8" }
        },
        {
            "name": "Markdown Headings",
            "scope": ["markup.heading"],
            "settings": { "foreground": "#c084fc", "fontStyle": "bold" }
        },
        {
            "name": "Erros",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#f472b6", "fontStyle": "bold" }
        },
        {
            "name": "Deprecado",
            "scope": ["invalid.deprecated"],
            "settings": { "foreground": "#1a0a2a" }
        }
    ]
}