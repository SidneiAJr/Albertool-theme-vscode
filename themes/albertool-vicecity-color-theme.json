{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Retro Vice",
    "type": "dark",
    "colors": {
        "editor.background": "#0f0818",
        "editor.foreground": "#d0c8e0",
        "activityBar.background": "#0f0818",
        "activityBar.foreground": "#ff2d75",
        "activityBar.inactiveForeground": "#4a2a5a",
        "activityBar.activeBorder": "#00e5ff",
        "sideBar.background": "#0f0818",
        "sideBar.foreground": "#b080cc",
        "sideBar.border": "#ff2d7522",
        "sideBarTitle.foreground": "#ff2d75",
        "sideBarSectionHeader.background": "#1a0a2a",
        "statusBar.background": "#0f0818",
        "statusBar.foreground": "#ff2d75",
        "statusBar.border": "#00e5ff22",
        "statusBar.debuggingBackground": "#ff2d75",
        "statusBar.debuggingForeground": "#ffffff",
        "titleBar.activeBackground": "#0f0818",
        "titleBar.activeForeground": "#ff2d75",
        "titleBar.inactiveBackground": "#0f0818",
        "titleBar.inactiveForeground": "#4a2a5a",
        "terminal.background": "#0f0818",
        "terminal.foreground": "#d0c8e0",
        "input.background": "#0f0818",
        "input.foreground": "#d0c8e0",
        "input.border": "#ff2d7544",
        "list.activeSelectionBackground": "#ff2d7522",
        "list.activeSelectionForeground": "#00e5ff",
        "list.hoverBackground": "#ff2d7511",
        "list.hoverForeground": "#d0c8e0",
        "tab.activeBackground": "#1a0a2a",
        "tab.activeForeground": "#00e5ff",
        "tab.inactiveBackground": "#0f0818",
        "tab.inactiveForeground": "#4a2a5a",
        "tab.border": "#ff2d7522",
        "button.background": "#ff2d75",
        "button.foreground": "#0f0818",
        "button.hoverBackground": "#e0256a",
        "badge.background": "#00e5ff",
        "badge.foreground": "#0f0818",
        "dropdown.background": "#0f0818",
        "dropdown.foreground": "#d0c8e0",
        "dropdown.border": "#ff2d7544",
        "editor.selectionBackground": "#00e5ff33",
        "editor.lineHighlightBackground": "#ff2d7511",
        "editorLineNumber.foreground": "#4a2a5a",
        "editorLineNumber.activeForeground": "#00e5ff",
        "scrollbarSlider.background": "#ff2d7533",
        "scrollbarSlider.hoverBackground": "#ff2d7555",
        "scrollbarSlider.activeBackground": "#ff2d7588",
        "focusBorder": "#00e5ff",
        "editorGroupHeader.tabsBackground": "#0f0818"
    },
    "tokenColors": [
        {
            "name": "Comentários",
            "scope": ["comment"],
            "settings": { "foreground": "#4a2a5a", "fontStyle": "italic" }
        },
        {
            "name": "Palavras-chave",
            "scope": [
                "keyword",
                "keyword.operator",
                "keyword.control",
                "keyword.control.flow",
                "keyword.control.loop",
                "keyword.control.conditional"
            ],
            "settings": { "foreground": "#ff2d75", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string", "string.quoted", "string.quoted.single", "string.quoted.double"],
            "settings": { "foreground": "#00e5ff" }
        },
        {
            "name": "Números",
            "scope": ["constant.numeric", "constant.hex", "constant.octal"],
            "settings": { "foreground": "#ffea00" }
        },
        {
            "name": "Funções",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#00e5ff", "fontStyle": "bold" }
        },
        {
            "name": "Classes",
            "scope": ["entity.name.class", "entity.name.type.class"],
            "settings": { "foreground": "#ff2d75", "fontStyle": "bold" }
        },
        {
            "name": "Variáveis",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#d0c8e0" }
        },
        {
            "name": "Constantes",
            "scope": ["constant", "constant.language"],
            "settings": { "foreground": "#ffea00" }
        },
        {
            "name": "Tipos",
            "scope": ["entity.name.type", "support.type", "storage.type"],
            "settings": { "foreground": "#b388ff", "fontStyle": "bold" }
        },
        {
            "name": "Operadores",
            "scope": ["keyword.operator", "keyword.operator.assignment"],
            "settings": { "foreground": "#ff2d75" }
        },
        {
            "name": "Tags HTML",
            "scope": ["meta.tag", "entity.name.tag"],
            "settings": { "foreground": "#ff2d75" }
        },
        {
            "name": "Atributos HTML",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#00e5ff" }
        },
        {
            "name": "CSS Props",
            "scope": ["support.type.property-name"],
            "settings": { "foreground": "#00e5ff" }
        },
        {
            "name": "CSS Values",
            "scope": ["support.constant.property-value"],
            "settings": { "foreground": "#ffea00" }
        },
        {
            "name": "JSON Keys",
            "scope": ["support.type.object.key"],
            "settings": { "foreground": "#00e5ff" }
        },
        {
            "name": "JSON Values",
            "scope": ["string.key.json"],
            "settings": { "foreground": "#ff2d75" }
        },
        {
            "name": "Markdown Headings",
            "scope": ["markup.heading", "markup.heading.1", "markup.heading.2"],
            "settings": { "foreground": "#00e5ff", "fontStyle": "bold" }
        },
        {
            "name": "Erros",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#ff0055", "fontStyle": "bold" }
        },
        {
            "name": "Deprecado",
            "scope": ["invalid.deprecated"],
            "settings": { "foreground": "#ffea00" }
        }
    ]
}