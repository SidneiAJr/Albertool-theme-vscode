{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Communist",
    "type": "dark",
    "colors": {
        "editor.background": "#1a0a0a",
        "editor.foreground": "#f0c0c0",
        "activityBar.background": "#0f0505",
        "activityBar.foreground": "#f0c0c0",
        "sideBar.background": "#0f0505",
        "sideBar.foreground": "#f0c0c0",
        "statusBar.background": "#0f0505",
        "statusBar.foreground": "#f0c0c0",
        "titleBar.activeBackground": "#0f0505",
        "titleBar.activeForeground": "#f0c0c0",
        "terminal.background": "#1a0a0a",
        "terminal.foreground": "#f0c0c0",
        "input.background": "#0f0505",
        "input.foreground": "#f0c0c0",
        "list.activeSelectionBackground": "#2a1515",
        "list.activeSelectionForeground": "#ffd700",
        "tab.activeBackground": "#1f0a0a",
        "tab.activeForeground": "#ffd700",
        "tab.inactiveBackground": "#0f0505",
        "tab.inactiveForeground": "#6a3a3a",
        "button.background": "#2a1515",
        "button.foreground": "#ffd700",
        "badge.background": "#ffd700",
        "badge.foreground": "#0f0505",
        "dropdown.background": "#0f0505",
        "dropdown.foreground": "#f0c0c0",
        "editor.selectionBackground": "#ffd70033",
        "editor.lineHighlightBackground": "#ffd70011",
        "editorLineNumber.foreground": "#6a3a3a",
        "editorLineNumber.activeForeground": "#ffd700",
        "scrollbarSlider.background": "#ffd70033",
        "scrollbarSlider.hoverBackground": "#ffd70055",
        "scrollbarSlider.activeBackground": "#ffd70088",
        "focusBorder": "#ffd700"
    },
    "tokenColors": [
        {
            "scope": "comment",
            "settings": { "foreground": "#6a3a3a", "fontStyle": "italic" }
        },
        {
            "scope": "keyword",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "keyword.operator",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "string",
            "settings": { "foreground": "#f0c0c0" }
        },
        {
            "scope": "constant.numeric",
            "settings": { "foreground": "#ffd700" }
        },
        {
            "scope": "entity.name.function",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "entity.name.class",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "variable",
            "settings": { "foreground": "#f0c0c0" }
        },
        {
            "scope": "entity.name.type",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "support.function",
            "settings": { "foreground": "#ffd700" }
        },
        {
            "scope": "constant.language",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "storage.type",
            "settings": { "foreground": "#ffd700", "fontStyle": "bold" }
        },
        {
            "scope": "invalid",
            "settings": { "foreground": "#ff0000", "fontStyle": "bold" }
        }
    ]
}