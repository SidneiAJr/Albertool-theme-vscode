{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Matrix",
    "type": "dark",
    "colors": {
        "editor.background": "#000000",
        "editor.foreground": "#00ff41",
        "activityBar.background": "#000000",
        "activityBar.foreground": "#00ff41",
        "activityBar.inactiveForeground": "#1a3a1a",
        "activityBar.activeBorder": "#00ff41",
        "sideBar.background": "#000000",
        "sideBar.foreground": "#00ff41",
        "sideBar.border": "#00ff4122",
        "sideBarTitle.foreground": "#00ff41",
        "sideBarSectionHeader.background": "#050a05",
        "statusBar.background": "#000000",
        "statusBar.foreground": "#00ff41",
        "statusBar.border": "#00ff4122",
        "statusBar.debuggingBackground": "#00ff41",
        "statusBar.debuggingForeground": "#000000",
        "titleBar.activeBackground": "#000000",
        "titleBar.activeForeground": "#00ff41",
        "titleBar.inactiveBackground": "#000000",
        "titleBar.inactiveForeground": "#1a3a1a",
        "terminal.background": "#000000",
        "terminal.foreground": "#00ff41",
        "input.background": "#000000",
        "input.foreground": "#00ff41",
        "input.border": "#00ff4144",
        "list.activeSelectionBackground": "#00ff4122",
        "list.activeSelectionForeground": "#00ff41",
        "list.hoverBackground": "#00ff4111",
        "list.hoverForeground": "#00ff41",
        "tab.activeBackground": "#050a05",
        "tab.activeForeground": "#00ff41",
        "tab.inactiveBackground": "#000000",
        "tab.inactiveForeground": "#1a3a1a",
        "tab.border": "#00ff4122",
        "button.background": "#00ff41",
        "button.foreground": "#000000",
        "button.hoverBackground": "#00d93a",
        "badge.background": "#00ff41",
        "badge.foreground": "#000000",
        "dropdown.background": "#000000",
        "dropdown.foreground": "#00ff41",
        "dropdown.border": "#00ff4144",
        "editor.selectionBackground": "#00ff4133",
        "editor.lineHighlightBackground": "#00ff4111",
        "editorLineNumber.foreground": "#1a3a1a",
        "editorLineNumber.activeForeground": "#00ff41",
        "scrollbarSlider.background": "#00ff4133",
        "scrollbarSlider.hoverBackground": "#00ff4155",
        "scrollbarSlider.activeBackground": "#00ff4188",
        "focusBorder": "#00ff41",
        "editorGroupHeader.tabsBackground": "#000000"
    },
    "tokenColors": [
        {
            "name": "Comentários",
            "scope": ["comment"],
            "settings": { "foreground": "#1a3a1a", "fontStyle": "italic" }
        },
        {
            "name": "Palavras-chave",
            "scope": [
                "keyword",
                "keyword.operator",
                "keyword.control",
                "keyword.control.flow",
                "keyword.control.loop",
                "keyword.control.conditional"
            ],
            "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
        },
        {
            "name": "Strings",
            "scope": ["string", "string.quoted", "string.quoted.single", "string.quoted.double"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "Números",
            "scope": ["constant.numeric", "constant.hex", "constant.octal"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "Funções",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
        },
        {
            "name": "Classes",
            "scope": ["entity.name.class", "entity.name.type.class"],
            "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
        },
        {
            "name": "Variáveis",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "Constantes",
            "scope": ["constant", "constant.language"],
            "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
        },
        {
            "name": "Tipos",
            "scope": ["entity.name.type", "support.type", "storage.type"],
            "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
        },
        {
            "name": "Operadores",
            "scope": ["keyword.operator", "keyword.operator.assignment"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "Tags HTML",
            "scope": ["meta.tag", "entity.name.tag"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "Atributos HTML",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "CSS Props",
            "scope": ["support.type.property-name"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "CSS Values",
            "scope": ["support.constant.property-value"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "JSON Keys",
            "scope": ["support.type.object.key"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "JSON Values",
            "scope": ["string.key.json"],
            "settings": { "foreground": "#00ff41" }
        },
        {
            "name": "Markdown Headings",
            "scope": ["markup.heading", "markup.heading.1", "markup.heading.2"],
            "settings": { "foreground": "#00ff41", "fontStyle": "bold" }
        },
        {
            "name": "Erros",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#ff0044", "fontStyle": "bold" }
        },
        {
            "name": "Deprecado",
            "scope": ["invalid.deprecated"],
            "settings": { "foreground": "#00ff41" }
        }
    ]
}