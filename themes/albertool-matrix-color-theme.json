{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Matrix",
    "type": "dark",
    "colors": {
        "focusBorder": "#4db840",
        "foreground": "#c8e6c8",
        "selection.background": "#4db84044",

        "editor.background": "#0a0f0a",
        "editor.foreground": "#c8e6c8",
        "editor.lineHighlightBackground": "#4db84011",
        "editor.selectionBackground": "#4db84033",
        "editor.selectionHighlightBackground": "#4db84022",
        "editor.inactiveSelectionBackground": "#4db84022",

        "editorBracketMatch.background": "#4db84033",
        "editorBracketMatch.border": "#4db840",

        "editorGutter.background": "#0a0f0a",
        "editorGutter.modifiedBackground": "#4db840",
        "editorGutter.addedBackground": "#2d8c2d",
        "editorGutter.deletedBackground": "#cc3300",

        "editorLineNumber.foreground": "#1a2e1a",
        "editorLineNumber.activeForeground": "#4db840",

        "editorGroupHeader.tabsBackground": "#0a0f0a",
        "tab.activeBackground": "#0f180f",
        "tab.activeForeground": "#4db840",
        "tab.inactiveBackground": "#0a0f0a",
        "tab.inactiveForeground": "#1a2e1a",
        "tab.border": "#4db84022",

        "activityBar.background": "#0a0f0a",
        "activityBar.foreground": "#4db840",
        "activityBar.inactiveForeground": "#1a2e1a",
        "activityBar.border": "#4db84022",
        "activityBar.activeBorder": "#4db840",

        "sideBar.background": "#0d120d",
        "sideBar.foreground": "#c8e6c8",
        "sideBar.border": "#4db84022",
        "sideBarTitle.foreground": "#4db840",
        "sideBarSectionHeader.background": "#0f180f",

        "statusBar.background": "#0a0f0a",
        "statusBar.foreground": "#4db840",
        "statusBar.border": "#4db84022",
        "statusBar.debuggingBackground": "#4db840",
        "statusBar.debuggingForeground": "#000000",

        "titleBar.activeBackground": "#0a0f0a",
        "titleBar.activeForeground": "#4db840",
        "titleBar.inactiveBackground": "#0a0f0a",
        "titleBar.inactiveForeground": "#1a2e1a",

        "list.activeSelectionBackground": "#0f180f",
        "list.activeSelectionForeground": "#4db840",
        "list.hoverBackground": "#4db84011",
        "list.hoverForeground": "#c8e6c8",
        "list.focusBackground": "#0f180f",
        "list.focusForeground": "#4db840",

        "input.background": "#0d120d",
        "input.foreground": "#c8e6c8",
        "input.border": "#4db84044",
        "input.placeholderForeground": "#1a2e1a",

        "dropdown.background": "#0d120d",
        "dropdown.foreground": "#c8e6c8",
        "dropdown.border": "#4db84044",

        "button.background": "#4db840",
        "button.foreground": "#000000",
        "button.hoverBackground": "#3a9030",

        "terminal.background": "#0a0f0a",
        "terminal.foreground": "#c8e6c8",

        "badge.background": "#4db840",
        "badge.foreground": "#000000",

        "scrollbarSlider.background": "#4db84033",
        "scrollbarSlider.hoverBackground": "#4db84055",
        "scrollbarSlider.activeBackground": "#4db84088",

        "peekViewResult.background": "#0d120d",
        "peekViewResult.selectionBackground": "#0f180f",
        "peekViewResult.lineForeground": "#c8e6c8",
        "peekViewResult.fileForeground": "#4db840",
        "peekViewEditor.background": "#0a0f0a",
        "peekViewEditorGutter.background": "#0a0f0a",
        "peekView.border": "#4db840"
    },
    "tokenColors": [
        {
            "name": "Comentários",
            "scope": ["comment"],
            "settings": { "foreground": "#2d4a2d", "fontStyle": "italic" }
        },
        {
            "name": "Palavras-chave",
            "scope": ["keyword", "keyword.control", "keyword.control.flow", "keyword.control.loop", "keyword.control.conditional"],
            "settings": { "foreground": "#4db840", "fontStyle": "bold" }
        },
        {
            "name": "Operadores",
            "scope": ["keyword.operator", "keyword.operator.assignment"],
            "settings": { "foreground": "#c8e6c8" }
        },
        {
            "name": "Strings",
            "scope": ["string", "string.quoted.single", "string.quoted.double"],
            "settings": { "foreground": "#7acc7a" }
        },
        {
            "name": "Números",
            "scope": ["constant.numeric", "constant.hex", "constant.octal"],
            "settings": { "foreground": "#a8d8a8" }
        },
        {
            "name": "Funções",
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#5dcc50", "fontStyle": "bold" }
        },
        {
            "name": "Classes",
            "scope": ["entity.name.class", "entity.name.type.class"],
            "settings": { "foreground": "#3a9030", "fontStyle": "bold" }
        },
        {
            "name": "Variáveis",
            "scope": ["variable", "variable.parameter", "variable.other"],
            "settings": { "foreground": "#c8e6c8" }
        },
        {
            "name": "Constantes",
            "scope": ["constant", "constant.language"],
            "settings": { "foreground": "#a8d8a8" }
        },
        {
            "name": "Tipos",
            "scope": ["entity.name.type", "support.type", "storage.type"],
            "settings": { "foreground": "#5dcc50" }
        },
        {
            "name": "Tags HTML",
            "scope": ["meta.tag", "entity.name.tag"],
            "settings": { "foreground": "#4db840" }
        },
        {
            "name": "Atributos HTML",
            "scope": ["entity.other.attribute-name"],
            "settings": { "foreground": "#7acc7a" }
        },
        {
            "name": "CSS Props",
            "scope": ["support.type.property-name"],
            "settings": { "foreground": "#5dcc50" }
        },
        {
            "name": "CSS Values",
            "scope": ["support.constant.property-value"],
            "settings": { "foreground": "#a8d8a8" }
        },
        {
            "name": "JSON Keys",
            "scope": ["support.type.object.key", "string.key.json"],
            "settings": { "foreground": "#5dcc50" }
        },
        {
            "name": "Markdown Headings",
            "scope": ["markup.heading"],
            "settings": { "foreground": "#4db840", "fontStyle": "bold" }
        },
        {
            "name": "Erros",
            "scope": ["invalid", "invalid.illegal"],
            "settings": { "foreground": "#cc3300", "fontStyle": "bold" }
        },
        {
            "name": "Deprecado",
            "scope": ["invalid.deprecated"],
            "settings": { "foreground": "#2d4a2d" }
        }
    ]
}