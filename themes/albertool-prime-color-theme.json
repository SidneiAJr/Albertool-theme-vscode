{
    "$schema": "vscode://schemas/color-theme",
    "name": "Albertool Prime",
    "type": "dark",
    "colors": {
        "editor.background": "#0a0a0a",
        "editor.foreground": "#f0d080",
        "activityBar.background": "#0a0a0a",
        "activityBar.foreground": "#f0d080",
        "sideBar.background": "#0a0a0a",
        "sideBar.foreground": "#f0d080",
        "statusBar.background": "#0a0a0a",
        "statusBar.foreground": "#f0d080",
        "titleBar.activeBackground": "#0a0a0a",
        "titleBar.activeForeground": "#f0d080",
        "terminal.background": "#0a0a0a",
        "terminal.foreground": "#f0d080",
        "input.background": "#0a0a0a",
        "input.foreground": "#f0d080",
        "list.activeSelectionBackground": "#1a1a0a",
        "list.activeSelectionForeground": "#f0d080",
        "tab.activeBackground": "#1a1a0a",
        "tab.activeForeground": "#f0d080",
        "tab.inactiveBackground": "#0a0a0a",
        "tab.inactiveForeground": "#5a4a2a",
        "button.background": "#1a1a0a",
        "button.foreground": "#f0d080",
        "badge.background": "#f0d080",
        "badge.foreground": "#0a0a0a",
        "dropdown.background": "#0a0a0a",
        "dropdown.foreground": "#f0d080",
        "editor.selectionBackground": "#f0d08033",
        "editor.lineHighlightBackground": "#f0d08011",
        "editorLineNumber.foreground": "#5a4a2a",
        "editorLineNumber.activeForeground": "#f0d080",
        "scrollbarSlider.background": "#f0d08033",
        "scrollbarSlider.hoverBackground": "#f0d08055",
        "scrollbarSlider.activeBackground": "#f0d08088",
        "focusBorder": "#f0d080"
    },
    "tokenColors": [
        {
            "scope": "comment",
            "settings": { "foreground": "#5a4a2a", "fontStyle": "italic" }
        },
        {
            "scope": "keyword",
            "settings": { "foreground": "#f0d080", "fontStyle": "bold" }
        },
        {
            "scope": "keyword.operator",
            "settings": { "foreground": "#f0d080" }
        },
        {
            "scope": "string",
            "settings": { "foreground": "#f0d080" }
        },
        {
            "scope": "constant.numeric",
            "settings": { "foreground": "#f0d080" }
        },
        {
            "scope": "entity.name.function",
            "settings": { "foreground": "#f0d080", "fontStyle": "bold" }
        },
        {
            "scope": "entity.name.class",
            "settings": { "foreground": "#f0d080", "fontStyle": "bold" }
        },
        {
            "scope": "variable",
            "settings": { "foreground": "#f0d080" }
        },
        {
            "scope": "entity.name.type",
            "settings": { "foreground": "#f0d080", "fontStyle": "bold" }
        },
        {
            "scope": "support.function",
            "settings": { "foreground": "#f0d080" }
        },
        {
            "scope": "constant.language",
            "settings": { "foreground": "#f0d080", "fontStyle": "bold" }
        },
        {
            "scope": "storage.type",
            "settings": { "foreground": "#f0d080", "fontStyle": "bold" }
        },
        {
            "scope": "entity.other.attribute-name",
            "settings": { "foreground": "#f0d080" }
        },
        {
            "scope": "support.type.property-name",
            "settings": { "foreground": "#f0d080" }
        }
    ]
}